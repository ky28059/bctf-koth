generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String       @id
  submissions Submission[]
  top         Json?
}

model Challenge {
  id          String       @id
  submissions Submission[]
}

model Submission {
  id        String    @id @default(uuid(7))
  status    Status
  body      String
  languages String[]  @default([])
  score     Int[]     @default([])
  error     String?
  tests     Json?
  ts        DateTime  @default(now())
  challId   String
  chall     Challenge @relation(fields: [challId], references: [id])
  userId    String
  user      User      @relation(fields: [userId], references: [id])
}

enum Status {
  QUEUED
  TESTING
  COMPLETED
}
